<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dimple's Nail Salon ✨</title>
  <link rel="stylesheet" href="style.css">
  <script src="script.js" defer></script>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <h1>Dimple's Nail Salon</h1>
    <p>Sparkle with simplicity 💅</p>
  </header>

  <!-- Navigation -->
  <nav class="menu-bar">
    <a href="#" onclick="showSection('homeAbout')">Home & About</a>
    <a href="#" onclick="showSection('contactSection')">Contact</a>
  </nav>

  <!-- Sidebar -->
  <aside class="slide-menu">
    <ul>
      <li><a href="#" onclick="showSection('activity1')">Welcome</a></li>
      <li><a href="#" onclick="showSection('activity2')">Client Info</a></li>
      <li><a href="#" onclick="showSection('activity3')">Price Calculator</a></li>
      <li><a href="#" onclick="showSection('activity4')">Appointment</a></li>
      <li><a href="#" onclick="showSection('activity5')">Age Check</a></li>
      <li><a href="#" onclick="showSection('activity6')">Queue</a></li>
      <li><a href="#" onclick="showSection('activity7')">Booking</a></li>
      <li><a href="#" onclick="showSection('activity8')">To‑Do List</a></li>
    </ul>
  </aside>

  <!-- Sections -->
  <main>
    <!-- Home + About side by side -->
    <section class="content" id="homeAbout">
      <div class="split">
        <div>
          <h2>Home</h2>
          <p>Minimal beauty, maximum sparkle ✨</p>
        </div>
        <div>
          <h2>About</h2>
          <input type="text" id="aboutInput" placeholder="Your nail style ✨">
        </div>
      </div>
    </section>

    <section class="content" id="contactSection" style="display:none;">
      <p>Email: nails@dimple.com</p>
      <p>Phone: 123-456-7890</p>
    </section>

    <!-- Activity Outputs -->
    <section class="content" id="activity1" style="display:none;">
      <button onclick="activity1()">Show Welcome</button>
      <div id="output1"></div>
    </section>

    <section class="content" id="activity2" style="display:none;">
      <input type="text" id="clientName" placeholder="Client name">
      <input type="text" id="clientService" placeholder="Service">
      <input type="text" id="clientTime" placeholder="Time">
      <button onclick="activity2()">Submit</button>
      <div id="output2"></div>
    </section>

    <section class="content" id="activity3" style="display:none;">
      <input type="number" id="price1" placeholder="Basic Manicure">
      <input type="number" id="price2" placeholder="Gel Polish">
      <input type="number" id="price3" placeholder="Nail Art">
      <button onclick="activity3()">Calculate</button>
      <div id="output3"></div>
    </section>

    <section class="content" id="activity4" style="display:none;">
      <input type="text" id="apptName" placeholder="Your name">
      <input type="text" id="apptColor" placeholder="Favorite nail color">
      <button onclick="activity4()">Book</button>
      <div id="output4"></div>
    </section>

    <section class="content" id="activity5" style="display:none;">
      <input type="number" id="ageInput" placeholder="Enter age">
      <button onclick="activity5()">Check</button>
      <div id="output5"></div>
    </section>

    <section class="content" id="activity6" style="display:none;">
      <input type="number" id="queueNum" placeholder="Queue size">
      <button onclick="activity6()">Show Queue</button>
      <div id="output6"></div>
    </section>

    <section class="content" id="activity7" style="display:none;">
      <button onclick="activity7()">Book Appointment</button>
      <div id="output7"></div>
    </section>

    <section class="content" id="activity8" style="display:none;">
      <input type="text" id="todoInput" placeholder="New task">
      <button onclick="addTodo()">Add</button>
      <ul id="todoList"></ul>
    </section>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <p>&copy; 2026 Dimple's Nail Salon</p>
  </footer>
</body>
</html>
